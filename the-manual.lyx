\end_inset


\begin_inset Quotes erd
\end_inset

 to the 
\begin_inset Flex Code
status open

\begin_layout Plain Layout
snapm._snapm
\end_layout

\end_inset

 module.
\end_layout

\begin_layout Enumerate
Add both those constants to the 
\begin_inset Flex Code
status open

\begin_layout Plain Layout
snapm._snapm
\end_layout

\end_inset

 module's 
\begin_inset Flex Code
status open

\begin_layout Plain Layout
__all__
