\begin_layout Plain Layout
tree_a
\end_layout

\end_inset

 —
 The "before" state (e.g.,
 snapshot at time T₀)
\end_layout

\begin_layout Itemize
\begin_inset Flex Code
status open

\begin_layout Plain Layout
tree_b
\end_layout

